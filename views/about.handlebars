        align-items: flex-start;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .feature-item:last-child { border-bottom: none; }

    .feature-dot {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #2d2d50;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .feature-item h6 {
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 2px;
        font-size: 0.95rem;
    }

    .feature-item p {
        color: #777;
        font-size: 0.85rem;
        margin: 0;
        line-height: 1.5;
    }

    .project-card {
        background: linear-gradient(135deg, #1a1a2e, #2d2d50);
        border-radius: 20px;
        padding: 28px;
        color: #fff;
        margin-bottom: 24px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    }

    .project-card h5 {
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 8px;
    }

    .project-card p {
        color: #a0aec0;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .btn-repo {
        background: linear-gradient(135deg, #32325a, #46467a);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 10px 24px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-repo:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 255, 255, 0.4);
        color: #ffffff;
    }

    .btn-repo svg { width: 18px; height: 18px; fill: #fff; }

    .stat-box {
        background: linear-gradient(135deg, #1a1a2e, #2d2d50);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        color: #fff;
        height: 100%;
